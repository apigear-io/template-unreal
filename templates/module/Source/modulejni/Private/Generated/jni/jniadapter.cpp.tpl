}

void {{$Class}}::Deinitialize()
{
	ApiGear::JavaServiceStarter::stopAdnroidServer("{{$javaClassPath}}/{{$javaClassName}}Starter");
	g{{$Class}}Handle = nullptr;
#if PLATFORM_ANDROID
